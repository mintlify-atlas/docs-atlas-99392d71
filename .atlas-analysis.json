    "LauncherState::get_from_config() - Get current launcher state",
    "Game::new() - Create game instance",
    "ComponentsLoader::new() - Load components index",
    "Sessions::set_current() - Switch active session",
    "anime_launcher_sdk::genshin::game::run() - Launch game",
    "VersionDiff::download() - Download game updates",
    "--debug - Enable debug logging",
    "--run-game - Run game directly",
    "--just-run-game - Force run game",
    "--session <name> - Switch session before launch"
